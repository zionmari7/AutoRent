# Copy this file to .env and fill in your values
# Never commit .env to version control

PORT=3000
DB_PATH=./autorent.db
NODE_ENV=development

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# CORS — comma-separated list of allowed origins
# In production: ALLOWED_ORIGINS=https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Monthly revenue target in PHP (used in Reports page)
MONTHLY_TARGET=50000

# Company details for invoices
COMPANY_NAME=AutoRent
COMPANY_ADDRESS=Calapan City, Oriental Mindoro
COMPANY_PHONE=+63 917 000 0000
COMPANY_EMAIL=autorent@email.com
COMPANY_TIN=
